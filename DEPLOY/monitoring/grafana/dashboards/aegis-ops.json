{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",     "id": "grafana",    "name": "Grafana",    "version": "10.2.0" },
    { "type": "datasource",  "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "AEGIS OMEGA X — All 14 Layers Operations Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🌍 LAYER 1 — PLANETARY DIGITAL TWIN",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color":    { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 0.8  }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Global Risk Score",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_global_risk_score", "legendFormat": "Risk" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active Cascades",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_active_cascades", "legendFormat": "Cascades" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "Compromised Assets",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_compromised_assets_total", "legendFormat": "Compromised" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 5,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Simulation Tick Duration (ms)",
      "type": "timeseries",
      "targets": [{ "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(aegis_simulation_tick_duration_ms_bucket[5m]))", "legendFormat": "p99" }, { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(aegis_simulation_tick_duration_ms_bucket[5m]))", "legendFormat": "p50" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "🧬 LAYER 2 — SECURITY GENOME",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "title": "Mutation Rate by Severity (per min)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(aegis_genome_mutations_total{severity='critical'}[1m])*60", "legendFormat": "Critical" },
        { "datasource": "Prometheus", "expr": "rate(aegis_genome_mutations_total{severity='high'}[1m])*60",     "legendFormat": "High" },
        { "datasource": "Prometheus", "expr": "rate(aegis_genome_mutations_total{severity='medium'}[1m])*60",   "legendFormat": "Medium" },
        { "datasource": "Prometheus", "expr": "rate(aegis_genome_mutations_total{severity='low'}[1m])*60",      "legendFormat": "Low" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] } } },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["mean"] } },
      "title": "Mutation Detection Lag (avg)",
      "type": "gauge",
      "targets": [{ "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(aegis_genome_mutation_detection_lag_seconds_bucket[5m]))", "legendFormat": "Detection Lag p50" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Resilience Score",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "avg(aegis_resilience_score)", "legendFormat": "Resilience" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 20,
      "title": "🌐 LAYER 3 — KNOWLEDGE UNIVERSE",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 12 },
      "id": 21,
      "title": "Knowledge Nodes Ingested (cumulative)",
      "type": "timeseries",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_knowledge_nodes_ingested_total", "legendFormat": "Total Nodes" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 12 },
      "id": 22,
      "title": "Semantic Search Latency",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(aegis_knowledge_search_duration_ms_bucket[5m]))", "legendFormat": "p99" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(aegis_knowledge_search_duration_ms_bucket[5m]))", "legendFormat": "p50" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 12 },
      "id": 23,
      "title": "Inference Engine — Rules Fired",
      "type": "timeseries",
      "targets": [{ "datasource": "Prometheus", "expr": "increase(aegis_knowledge_inferences_total[1h])", "legendFormat": "Inferences/hr" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 30,
      "title": "🤖 LAYER 4 — AI CIVILIZATION",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 18 },
      "id": 31,
      "title": "Agent Task Throughput by Class",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(aegis_agent_tasks_completed_total{class='analyst'}[1m])*60",      "legendFormat": "Analyst" },
        { "datasource": "Prometheus", "expr": "rate(aegis_agent_tasks_completed_total{class='detection'}[1m])*60",    "legendFormat": "Detection" },
        { "datasource": "Prometheus", "expr": "rate(aegis_agent_tasks_completed_total{class='intelligence'}[1m])*60", "legendFormat": "Intelligence" },
        { "datasource": "Prometheus", "expr": "rate(aegis_agent_tasks_completed_total{class='risk'}[1m])*60",         "legendFormat": "Risk" },
        { "datasource": "Prometheus", "expr": "rate(aegis_agent_tasks_completed_total{class='governance'}[1m])*60",   "legendFormat": "Governance" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 18 },
      "id": 32,
      "title": "Agent Trust Scores",
      "type": "bargauge",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_agent_trust_score", "legendFormat": "{{agent_id}}" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 40,
      "title": "🚨 LAYER 5 — AUTONOMOUS SOC",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "id": 41,
      "options": { "colorMode": "background" },
      "title": "Critical Alerts (Unacked)",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_soc_critical_alerts_unacked", "legendFormat": "Critical" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "id": 42,
      "title": "Mean Time To Respond (MTTR)",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_soc_mttr_seconds", "legendFormat": "MTTR" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 24 },
      "id": 43,
      "title": "False Positive Rate",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_soc_false_positive_rate", "legendFormat": "FP Rate" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "id": 44,
      "title": "SOC Alert Volume by Severity",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(aegis_soc_alerts_total{severity='critical'}[5m])*300", "legendFormat": "Critical/5m" },
        { "datasource": "Prometheus", "expr": "rate(aegis_soc_alerts_total{severity='high'}[5m])*300",     "legendFormat": "High/5m" },
        { "datasource": "Prometheus", "expr": "rate(aegis_soc_alerts_total{severity='medium'}[5m])*300",   "legendFormat": "Medium/5m" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 50,
      "title": "⚛️  LAYER 13 — QUANTUM-SAFE | 🏭 LAYER 14 — CYBER-PHYSICAL",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "id": 51,
      "options": { "colorMode": "background" },
      "title": "Quantum-Vulnerable Algos Exposed",
      "type": "stat",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_quantum_vulnerable_algorithms_exposed", "legendFormat": "Vulnerable" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "id": 52,
      "title": "PQC Migration Progress",
      "type": "gauge",
      "targets": [{ "datasource": "Prometheus", "expr": "aegis_pqc_migration_progress", "legendFormat": "Migration %" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 29 },
      "id": 53,
      "title": "CPS Avg Resilience Score",
      "type": "gauge",
      "targets": [{ "datasource": "Prometheus", "expr": "avg(aegis_cps_resilience_score)", "legendFormat": "CPS Resilience" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 29 },
      "id": 54,
      "title": "CPS Max Cyber Risk",
      "type": "gauge",
      "targets": [{ "datasource": "Prometheus", "expr": "max(aegis_cps_cyber_risk)", "legendFormat": "Max CPS Risk" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 60,
      "title": "🏗️  INFRASTRUCTURE",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 34 },
      "id": 61,
      "title": "API Request Rate (all services)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(aegis_api_requests_total{service='pdt-api'}[1m])*60",      "legendFormat": "PDT API" },
        { "datasource": "Prometheus", "expr": "rate(aegis_api_requests_total{service='genome-api'}[1m])*60",   "legendFormat": "Genome API" },
        { "datasource": "Prometheus", "expr": "rate(aegis_api_requests_total{service='knowledge-api'}[1m])*60","legendFormat": "KU API" },
        { "datasource": "Prometheus", "expr": "rate(aegis_api_requests_total{service='gateway'}[1m])*60",      "legendFormat": "Gateway" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 34 },
      "id": 62,
      "title": "API p99 Latency (ms)",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(aegis_api_request_duration_seconds_bucket{service='pdt-api'}[5m]))*1000",      "legendFormat": "PDT p99" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(aegis_api_request_duration_seconds_bucket{service='genome-api'}[5m]))*1000",   "legendFormat": "Genome p99" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(aegis_api_request_duration_seconds_bucket{service='knowledge-api'}[5m]))*1000","legendFormat": "KU p99" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 34 },
      "id": 63,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "targets": [
        { "datasource": "Prometheus", "expr": "kafka_consumer_lag_sum{topic='telemetry.assets'}",       "legendFormat": "Assets" },
        { "datasource": "Prometheus", "expr": "kafka_consumer_lag_sum{topic='genome.mutations'}",       "legendFormat": "Mutations" },
        { "datasource": "Prometheus", "expr": "kafka_consumer_lag_sum{topic='knowledge.ingest'}",       "legendFormat": "KU Ingest" },
        { "datasource": "Prometheus", "expr": "kafka_consumer_lag_sum{topic='soc.alerts'}",             "legendFormat": "SOC Alerts" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["aegis-omega-x", "security", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AEGIS OMEGA X — Operations Dashboard",
  "uid": "aegis-omega-x-ops",
  "version": 1
}
